{
  "name": "showtimex",
  "version": "1.0.0",
  "description": "showtimex is an OSS ticket booking application",
  "main": "app.js",
  "scripts": {
    "dev": "docker compose -f ./docker/docker-compose.dev.yaml up --build",
    "build": "docker compose -f ./docker/docker-compose.yaml up --build",
    "docker:down": "docker compose down --volumes",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:create": "node -e \"const name=process.argv[1]; require('child_process').spawnSync('npm',['run','typeorm','--','migration:create','./src/migrations/'+name],{stdio:'inherit'});\"",
    "migration:generate": "node -e \"const name=process.argv[1]; require('child_process').spawnSync('cross-env',['TYPEORM_ENV_CONFIG_PATH=./env/.env.local','npm','run','typeorm','--','migration:generate','./src/migrations/'+name,'-d','./src/lib/typeorm/typeorm.index'],{stdio:'inherit'});\"",
    "migration:run": "cross-env TYPEORM_ENV_CONFIG_PATH=./env/.env.local npm run typeorm -- migration:run -d ./src/lib/typeorm/typeorm.index",
    "migration:run:fake": "cross-env TYPEORM_ENV_CONFIG_PATH=./env/.env.local npm run typeorm -- migration:run --fake -d ./src/lib/typeorm/typeorm.index",
    "migration:revert": "cross-env TYPEORM_ENV_CONFIG_PATH=./env/.env.local npm run typeorm -- migration:revert -d ./src/lib/typeorm/typeorm.index",
    "test": "echo \"No tests yet\""
  },
  "author": "Vasil Sarandev",
  "license": "ISC",
  "devDependencies": {
    "@eslint/css": "^0.9.0",
    "@eslint/js": "^9.29.0",
    "@eslint/json": "^0.12.0",
    "@types/express": "^4.17.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.2.1",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.0",
    "globals": "^16.2.0",
    "prettier": "3.5.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.0.0",
    "class-validator": "^0.14.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.17.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "stripe": "^18.5.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.25",
    "yamljs": "^0.3.0"
  }
}
